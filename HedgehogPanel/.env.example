# Hedgehog Panel configuration (.env example)
# Copy this file to .env and edit values.

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hedgehog_panel
DB_USER=hedgehog
DB_PASSWORD=your_db_password

# JWT settings (used by helper methods and optional JWT flows)
# IMPORTANT: JWT_SECRET must be at least 32 bytes (256 bits) long for HS256.
# Example 32+ byte secret (DO NOT use this in production):
# JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_SECRET=
JWT_ISSUER=HedgehogPanel
JWT_AUDIENCE=HedgehogPanel.Client
